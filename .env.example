# ServerlessAgent — Local Development Environment
# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.
#
# NOTE: Sensitive credentials (Google keys, Weather API key, Gmail)
# are stored in AWS Secrets Manager, not here.
# See README.md → Getting Started → Step 2 for setup instructions.

# -----------------------------------------------------------------------
# Required for all local runs
# -----------------------------------------------------------------------

# DynamoDB session table name — copy from CDK deploy output
# e.g. AgentDbStack-SessionTableXXXXXXXX-XXXXXXXXXXXX
TABLE_NAME=

# DynamoDB notes table name — copy from CDK deploy output
NOTES_TABLE_NAME=

# DynamoDB expenses table name — copy from CDK deploy output
EXPENSES_TABLE_NAME=

# AWS region (must match your CDK deploy region)
REGION=eu-central-1

# -----------------------------------------------------------------------
# Required for local runs that use skills (bypasses Secrets Manager)
# In production these are loaded from AWS Secrets Manager automatically.
# -----------------------------------------------------------------------

# Google Calendar & Gmail (from your GCP Service Account JSON)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...[your key]...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your-email@gmail.com

# Gmail sending — requires domain-wide delegation on the service account
GMAIL_SENDER_EMAIL=your-email@gmail.com

# OpenWeatherMap — free tier at openweathermap.org
WEATHER_API_KEY=

# -----------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------

# Bedrock model override (default: eu.amazon.nova-pro-v1:0)
# MODEL_ID=eu.amazon.nova-pro-v1:0

# CORS allowed origin for API Gateway (leave blank to allow all)
# ALLOWED_ORIGIN=https://yourdomain.com

# Local testing only — overrides Secrets Manager lookup
# SECRET_NAME=ServerlessAgent/credentials
