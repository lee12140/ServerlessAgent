# 🚦 OpenClaw Environment Configuration
# Copy this to a file named '.env' in the same directory!

# 🧠 Core Security
API_KEY=OC-9f8e7d6c5b4a3210

# 📅 Google Calendar (Service Account)
# Get these from your Google Cloud Console Service Account JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...[your key]...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your-email@gmail.com

# 🌍 AWS Region
AWS_REGION=eu-central-1

# 🗄️ DynamoDB Table (for local testing with test-local.ts — find value in CDK deploy output)
TABLE_NAME=OpenClawDbStack-SessionTable-XXXXXXXXXXXX

# 🌐 CORS — restrict API access to your homepage only (leave blank to allow all origins)
ALLOWED_ORIGIN=https://yourdomain.com
